loop = True
print("Shopping list")
print("You can add any items in your shopping list")
print("Just type 'QUIT' to stop adding items")
print("Just type 'VIEW' to view your listed items")
print("Just type 'DELETE' to delete your listed items")

shopping_list = []

while loop:
    new_item = input("Add an item: ")

    if new_item == "QUIT":
        print("Saving.....exiting program")
        loop = False
    elif new_item == "VIEW":
        print(f"{shopping_list}")
    elif new_item == "DELETE":
        delete_item = input("Delete an item: ")

        if delete_item in shopping_list:
            shopping_list.remove(delete_item)
            print(f"{shopping_list} deleted")
        else:
            print(f"{shopping_list} not found")
    else:
        shopping_list.append(new_item)

for i, item in enumerate(shopping_list):
    print(f"{i + 1}. {item}")
